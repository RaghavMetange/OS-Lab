#include<stdio.h>
#define MAX 10

int main() {
	int n, i, j;
	int bt[MAX], wt[MAX], tat[MAX];
	int p[MAX];
	float avg_wt = 0, avg_tat = 0;

	printf("Enter number of processes (max 10): ");
	scanf("%d", &n);

	if (n> MAX) {
	printf("Maximum number of processes is 10.\n");
	return 1;
	}

	for (i = 0; i < n; i++) {
		p[i] = i + 1;
		printf("Enter burst time for process P%d: ", p[i]);
		scanf("%d", &bt[i]);
	}

	for (i= 0; i < n; i++) {
		for (j = i + 1; j < n; j++) {
			if (bt[i] > bt[j]) {
				int temp = bt[i];
				bt[i] = bt[j];
				bt[j] = temp;
				temp = p[i];
				p[i] = p[j];
				p[j] = temp;
			}
		}
	}

	wt[0] = 0;
	for (i = 0; i < n; i++) {
		wt[i] = wt[i-1] + bt[i-1];
	}

	for (i = 0; i < n; i++) {
		tat[i] = wt[i] + bt[i];
		avg_wt += wt[i];
		avg_tat += tat[i];
	}

	avg_wt /= n;
	avg_tat /= n;

	printf("\nProcesses\tBurst Time\tWaiting Time\tTurnaround Time\n");
	for (i = 0; i < n; i++) {
		printf("P%d\t\t%d\t\t%d\t\t%d\n", p[i], bt[i], wt[i], tat[i]);
	}

	printf("\nAverage Waiting Time  = %.2f", avg_wt);
	printf("\nAverage Turnaround Time = %.2f", avg_tat);

	return 0;
}
